# Monitoring agent config — copy to /etc/monitoring-agent.conf on each machine
# chmod 600 recommended (contains a password)

DOMAIN="monitoring2.neolao.com"
WRITE_USER="writer"
WRITE_PASS="plaintext_password_of_the_writer_account"

# Name identifying this machine in the metrics (the "host" label).
# Leave empty to automatically use $(hostname), or force a
# unique value here if multiple machines might share the same hostname.
HOST_NAME=""
