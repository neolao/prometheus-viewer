# Config de l'agent de monitoring — à copier vers /etc/monitoring-agent.conf sur chaque machine
# chmod 600 recommandé (contient un mot de passe)

DOMAIN="monitoring2.neolao.com"
WRITE_USER="writer"
WRITE_PASS="le_mot_de_passe_en_clair_du_compte_writer"

# Nom identifiant cette machine dans les métriques (label "host").
# Laisse vide pour utiliser $(hostname) automatiquement, ou force une valeur
# unique ici si plusieurs machines risquent de partager le même hostname.
HOST_NAME=""
