# Domain pointing to this server (DNS A record required for Caddy's automatic TLS)
DOMAIN=monitoring.yourdomain.example

# Admin credentials (Alertmanager UI)
ADMIN_USER=admin
# Generate the hash with: docker run --rm caddy caddy hash-password --plaintext 'your_password'
ADMIN_PASS_HASH=

# Write credentials (used by the bash script on each machine for the curl POST)
WRITE_USER=writer
WRITE_PASS_HASH=

# Read credentials (used by your Grafana instance to query the data)
READ_USER=reader
READ_PASS_HASH=
