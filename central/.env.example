# Domaine pointant vers ce serveur (A record DNS requis pour le TLS auto de Caddy)
DOMAIN=monitoring.tondomaine.fr

# Identifiants admin (interface Alertmanager)
ADMIN_USER=admin
# Générer le hash avec : docker run --rm caddy caddy hash-password --plaintext 'ton_mot_de_passe'
ADMIN_PASS_HASH=

# Identifiants d'écriture (utilisés par le script bash sur chaque machine pour le curl POST)
WRITE_USER=writer
WRITE_PASS_HASH=

# Identifiants de lecture (utilisés par Grafana chez toi pour interroger les données)
READ_USER=reader
READ_PASS_HASH=
