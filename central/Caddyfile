{$DOMAIN} {

	log {
		output file /var/log/caddy/access.log
		format json
	}

	# Alertmanager : pas de login natif, on protège l'accès à son interface.
	handle /alertmanager* {
		basicauth {
			{$ADMIN_USER} {$ADMIN_PASS_HASH}
		}
		reverse_proxy alertmanager:9093
	}

	# Ingestion : endpoints d'écriture utilisés par le script bash sur chaque machine.
	handle /api/v1/import/* {
		basicauth {
			{$WRITE_USER} {$WRITE_PASS_HASH}
		}
		reverse_proxy victoriametrics:8428
	}

	handle /api/v1/write {
		basicauth {
			{$WRITE_USER} {$WRITE_PASS_HASH}
		}
		reverse_proxy victoriametrics:8428
	}

	# Lecture : utilisé par Grafana (hébergé chez toi) pour interroger les données.
	# Identifiants séparés de ceux d'écriture — un client qui pousse des métriques
	# ne peut pas lire les données, et inversement.
	handle /api/v1/query* {
		basicauth {
			{$READ_USER} {$READ_PASS_HASH}
		}
		reverse_proxy victoriametrics:8428
	}

	handle /api/v1/label* {
		basicauth {
			{$READ_USER} {$READ_PASS_HASH}
		}
		reverse_proxy victoriametrics:8428
	}

	handle /api/v1/series* {
		basicauth {
			{$READ_USER} {$READ_PASS_HASH}
		}
		reverse_proxy victoriametrics:8428
	}

	handle {
		respond "Not found" 404
	}
}
