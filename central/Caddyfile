{$DOMAIN} {

	log {
		output file /var/log/caddy/access.log {
			roll_size 10MiB
			roll_keep 5
			roll_keep_for 720h
		}
		format json
	}

	# Alertmanager: no built-in login, so we protect access to its UI.
	handle /alertmanager* {
		basicauth {
			{$ADMIN_USER} {$ADMIN_PASS_HASH}
		}
		reverse_proxy alertmanager:9093
	}

	# Ingestion: write endpoints used by the bash script on each machine.
	handle /api/v1/import/* {
		basicauth {
			{$WRITE_USER} {$WRITE_PASS_HASH}
		}
		reverse_proxy victoriametrics:8428
	}

	handle /api/v1/write {
		basicauth {
			{$WRITE_USER} {$WRITE_PASS_HASH}
		}
		reverse_proxy victoriametrics:8428
	}

	# Read: used by Grafana (hosted on your side) to query the data.
	# Credentials separate from the write ones — a client that pushes metrics
	# cannot read the data, and vice versa.
	handle /api/v1/query* {
		basicauth {
			{$READ_USER} {$READ_PASS_HASH}
		}
		reverse_proxy victoriametrics:8428
	}

	handle /api/v1/label* {
		basicauth {
			{$READ_USER} {$READ_PASS_HASH}
		}
		reverse_proxy victoriametrics:8428
	}

	handle /api/v1/series* {
		basicauth {
			{$READ_USER} {$READ_PASS_HASH}
		}
		reverse_proxy victoriametrics:8428
	}

	handle {
		respond "Not found" 404
	}
}
