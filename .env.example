# Copier ce fichier en .env.local et adapter les valeurs.
# Ces variables sont lues uniquement côté serveur Node (jamais par le
# navigateur) — le client web appelle toujours le même serveur, qui relaie
# vers Prometheus. Pas de problème de CORS possible avec ce schéma.

# URL du serveur Prometheus à interroger (sans slash final).
PROMETHEUS_URL=http://localhost:9090

# Optionnel — si Prometheus exige une authentification HTTP Basic, le
# serveur ajoutera lui-même l'en-tête Authorization à chaque requête.
# Laisser vide/absent si Prometheus est ouvert.
# PROMETHEUS_USERNAME=
# PROMETHEUS_PASSWORD=

# Port d'écoute du serveur Node (optionnel, 3000 par défaut).
# PORT=3000
